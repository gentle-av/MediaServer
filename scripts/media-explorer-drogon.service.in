[Unit]
Description=Media Explorer Drogon Web Interface
After=network.target
Wants=network.target

[Service]
Type=simple
User=avr
Group=avr
WorkingDirectory=/home/avr
ExecStart=/usr/local/bin/media_explorer_drogon
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=media-explorer-drogon

# Разрешаем запись в домашнюю директорию
NoNewPrivileges=no
PrivateTmp=yes
ProtectSystem=no
ProtectHome=read-only
ReadWritePaths=/home/avr/.local/share/media-explorer-drogon /home/avr/code/projects/cpp/build/MediaServer /var/log/media-explorer-drogon

[Install]
WantedBy=multi-user.target
