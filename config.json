{
    "app": {
        "number_of_threads": 4,
        "root": "",
        "static_path": "static",
        "static_file_headers": [
            {
                "headers": ["Access-Control-Allow-Origin: *"],
                "path": "/"
            }
        ],
        "document_root": "./views",
        "upload_path": "uploads",
        "client_max_body_size": "16M",
        "client_max_body_size_in_mb": 16,
        "log": {
            "log_path": "./logs",
            "logfile_base_name": "media-explorer",
            "log_size_limit": 100000000,
            "log_level": "DEBUG"
        }
    },
    "listeners": [
        {
            "address": "0.0.0.0",
            "port": 8083,
            "https": false
        }
    ]
}
